# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# Also set these same values in Vercel → Project Settings → Environment Variables
# for production, so the live site picks them up on next deploy.

# Supabase — from Project Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic — powers the AI PDF/image inventory parser (admin Upload tab).
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Resend — powers order-confirmation + admin-notification emails.
# These are SERVER-SIDE ONLY (used by the Vercel serverless function
# at /api/send-order-email). Never prefix with VITE_.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
# The address that order notifications are sent TO (your nursery's inbox).
ADMIN_NOTIFY_EMAIL=parkgreenhouse@proton.me
# The verified "From" address Resend sends as.
# Use "onboarding@resend.dev" for testing, or add your own domain in Resend.
ORDER_FROM_EMAIL=Park Greenhouse <onboarding@resend.dev>
